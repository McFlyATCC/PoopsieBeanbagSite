---
import { Image } from "astro:assets";
import galleryData from "../data/gallery.json";

interface Photo {
  src: string;
  year: number;
  caption?: string;
}
const photos = (galleryData.photos as Photo[]) ?? [];

// Resolve any real images dropped into src/assets/gallery/ (incl. subfolders
// like champions/). Keyed by the path relative to the gallery folder, so a
// manifest `src` can be "2017.jpg" or "champions/2017.jpg".
const files = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/gallery/**/*.{jpg,jpeg,png,webp,avif}",
  { eager: true },
);
const byName: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(files)) {
  const rel = path.split("/gallery/")[1]; // e.g. "champions/2017.jpg"
  if (rel) byName[rel] = mod.default;
}

const years = [...new Set(photos.map((p) => p.year))].sort((a, b) => b - a);
---

<div class="gallery">
  <div class="gallery__filter" role="group" aria-label="Filter photos by year">
    <button class="gallery__chip is-active" data-year="all" type="button">All</button>
    {
      years.map((y) => (
        <button class="gallery__chip" data-year={y} type="button">
          {y}
        </button>
      ))
    }
  </div>

  <ul class="gallery__grid">
    {
      photos.map((p, i) => {
        const img = byName[p.src];
        return (
          <li class="gallery__cell" data-year={p.year}>
            <button
              class="gallery__tile"
              type="button"
              data-index={i}
              data-caption={p.caption ?? ""}
              data-year={p.year}
            >
              <figure class="gallery__fig">
                {img ? (
                  <Image src={img} alt={p.caption ?? `Photo from ${p.year}`} widths={[300, 600]} sizes="(max-width: 640px) 45vw, 300px" class="gallery__img" />
                ) : (
                  <span class="gallery__ph" aria-hidden="true">
                    <span class="gallery__ph-ring" />
                    <span class="gallery__ph-year stat-face">{p.year}</span>
                    <span class="gallery__ph-txt">Photo coming soon</span>
                  </span>
                )}
                {p.caption && <figcaption class="gallery__cap">{p.caption}</figcaption>}
              </figure>
            </button>
          </li>
        );
      })
    }
  </ul>
</div>

<!-- Lightbox -->
<div class="lb" data-lightbox hidden aria-hidden="true">
  <div class="lb__backdrop" data-lb-close></div>
  <div class="lb__dialog" role="dialog" aria-modal="true" aria-label="Photo viewer">
    <button class="lb__btn lb__close" data-lb-close type="button" aria-label="Close">✕</button>
    <button class="lb__btn lb__prev" data-lb-prev type="button" aria-label="Previous photo">‹</button>
    <div class="lb__stage" data-lb-stage></div>
    <button class="lb__btn lb__next" data-lb-next type="button" aria-label="Next photo">›</button>
  </div>
</div>

<script>
  function initGallery() {
    const root = document.querySelector<HTMLElement>(".gallery");
    const lb = document.querySelector<HTMLElement>("[data-lightbox]");
    if (!root || !lb) return;

    // Year filtering
    const chips = root.querySelectorAll<HTMLButtonElement>(".gallery__chip");
    const cells = root.querySelectorAll<HTMLElement>(".gallery__cell");
    chips.forEach((chip) => {
      chip.addEventListener("click", () => {
        chips.forEach((c) => c.classList.remove("is-active"));
        chip.classList.add("is-active");
        const y = chip.dataset.year;
        cells.forEach((cell) => {
          cell.hidden = !(y === "all" || cell.dataset.year === y);
        });
      });
    });

    // Lightbox
    const stage = lb.querySelector<HTMLElement>("[data-lb-stage]")!;
    let visibleTiles: HTMLButtonElement[] = [];
    let pos = 0;
    let lastFocused: HTMLElement | null = null;

    function currentTiles() {
      return [...root.querySelectorAll<HTMLButtonElement>(".gallery__tile")].filter(
        (t) => !(t.closest(".gallery__cell") as HTMLElement)?.hidden,
      );
    }
    function render() {
      const tile = visibleTiles[pos];
      if (!tile) return;
      const fig = tile.querySelector(".gallery__fig");
      stage.innerHTML = fig ? fig.outerHTML : "";
    }
    function open(tile: HTMLButtonElement) {
      visibleTiles = currentTiles();
      pos = visibleTiles.indexOf(tile);
      lastFocused = document.activeElement as HTMLElement;
      render();
      lb!.hidden = false;
      lb!.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
      (lb!.querySelector(".lb__close") as HTMLElement)?.focus();
    }
    function close() {
      lb!.hidden = true;
      lb!.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      lastFocused?.focus();
    }
    function step(n: number) {
      if (!visibleTiles.length) return;
      pos = (pos + n + visibleTiles.length) % visibleTiles.length;
      render();
    }

    root.querySelectorAll<HTMLButtonElement>(".gallery__tile").forEach((tile) => {
      tile.addEventListener("click", () => open(tile));
    });
    lb.querySelectorAll("[data-lb-close]").forEach((b) => b.addEventListener("click", close));
    lb.querySelector("[data-lb-prev]")?.addEventListener("click", () => step(-1));
    lb.querySelector("[data-lb-next]")?.addEventListener("click", () => step(1));
    document.addEventListener("keydown", (e) => {
      if (lb.hidden) return;
      if (e.key === "Escape") close();
      if (e.key === "ArrowLeft") step(-1);
      if (e.key === "ArrowRight") step(1);
    });
  }
  document.addEventListener("astro:page-load", initGallery);
</script>

<style>
  .gallery__filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
  }
  .gallery__chip {
    font-family: var(--font-accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.75rem;
    padding: 0.35rem 0.8rem;
    background: transparent;
    border: 1.5px solid color-mix(in srgb, var(--color-lake-deep) 40%, transparent);
    color: var(--color-ink-soft);
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .gallery__chip:hover {
    border-color: var(--color-amber-deep);
  }
  .gallery__chip.is-active {
    background: var(--color-lake-deep);
    color: var(--color-paper);
    border-color: var(--color-lake-deep);
  }

  .gallery__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 15rem), 1fr));
    gap: 1rem;
  }
  .gallery__tile {
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    text-align: left;
  }
  .gallery__fig {
    margin: 0;
    position: relative;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-ink) 14%, transparent);
    background: var(--color-paper);
    box-shadow: 0 12px 30px -26px var(--color-lake-deep);
  }
  .gallery__img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .gallery__tile:hover .gallery__img {
    transform: scale(1.04);
  }
  .gallery__ph {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    aspect-ratio: 4 / 3;
    gap: 0.3rem;
    background: radial-gradient(
      circle at center,
      color-mix(in srgb, var(--color-amber) 18%, var(--color-paper)),
      var(--color-canvas-deep)
    );
  }
  .gallery__ph-ring {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    border: 4px solid var(--color-amber);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-agate) 40%, transparent);
  }
  .gallery__ph-year {
    font-size: 1.3rem;
    color: var(--color-lake-deep);
    margin-top: 0.4rem;
  }
  .gallery__ph-txt {
    font-family: var(--font-accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.68rem;
    color: var(--color-ink-faint);
  }
  .gallery__cap {
    padding: 0.6rem 0.75rem;
    font-size: 0.88rem;
    color: var(--color-ink-soft);
    font-style: italic;
    border-top: 1px solid color-mix(in srgb, var(--color-ink) 10%, transparent);
  }

  /* Lightbox */
  .lb[hidden] {
    display: none;
  }
  .lb {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: grid;
    place-items: center;
  }
  .lb__backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--color-lake-deep) 90%, black);
    opacity: 0.94;
  }
  .lb__dialog {
    position: relative;
    z-index: 1;
    width: min(58rem, 92vw);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.5rem;
  }
  .lb__stage {
    max-height: 82vh;
    overflow: hidden;
  }
  .lb__stage :global(.gallery__fig) {
    box-shadow: none;
    background: var(--color-paper);
  }
  .lb__stage :global(.gallery__img),
  .lb__stage :global(.gallery__ph) {
    aspect-ratio: auto;
    max-height: 74vh;
    width: 100%;
    object-fit: contain;
  }
  .lb__stage :global(.gallery__ph) {
    min-height: 40vh;
  }
  .lb__btn {
    background: color-mix(in srgb, var(--color-paper) 15%, transparent);
    color: var(--color-paper);
    border: 1.5px solid color-mix(in srgb, var(--color-paper) 40%, transparent);
    width: 2.75rem;
    height: 2.75rem;
    font-size: 1.3rem;
    cursor: pointer;
    display: grid;
    place-items: center;
    transition: background 0.15s ease;
  }
  .lb__btn:hover {
    background: var(--color-amber);
    color: var(--color-lake-deep);
  }
  .lb__close {
    position: absolute;
    top: -3.4rem;
    right: 0;
  }

  @media (max-width: 560px) {
    .lb__close {
      top: -3rem;
    }
    .lb__btn {
      width: 2.4rem;
      height: 2.4rem;
    }
  }
</style>
