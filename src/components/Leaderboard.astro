---
interface Row {
  name: string;
  value: string | number;
  detail?: string;
}
interface Props {
  title: string;
  unit?: string;
  rows: Row[];
}
const { title, unit, rows } = Astro.props;
---

<div class="board card-paper" data-reveal>
  <div class="board__head">
    <h3 class="board__title">{title}</h3>
    {unit && <span class="board__unit eyebrow">{unit}</span>}
  </div>
  <ol class="board__list">
    {
      rows.map((r, i) => (
        <li class="board__row">
          <span class="board__rank stat-face">{i + 1}</span>
          <span class="board__name">
            {r.name}
            {r.detail && <span class="board__detail">{r.detail}</span>}
          </span>
          <span class="board__value stat-face">{r.value}</span>
        </li>
      ))
    }
  </ol>
</div>

<style>
  .board {
    padding: 1.4rem 1.5rem 1.5rem;
  }
  .board__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    border-bottom: 2px solid var(--color-agate);
    padding-bottom: 0.6rem;
    margin-bottom: 0.4rem;
  }
  .board__title {
    font-size: 1.35rem;
    margin: 0;
  }
  .board__unit {
    color: var(--color-ink-faint);
    font-size: 0.66rem;
  }
  .board__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .board__row {
    display: grid;
    grid-template-columns: 1.6rem 1fr auto;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.55rem 0;
    border-bottom: 1px dashed color-mix(in srgb, var(--color-ink) 14%, transparent);
  }
  .board__row:last-child {
    border-bottom: none;
  }
  .board__rank {
    color: var(--color-amber-deep);
    font-size: 1rem;
    text-align: right;
  }
  .board__name {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--color-lake-deep);
    display: flex;
    flex-direction: column;
  }
  .board__detail {
    font-family: var(--font-body);
    font-weight: 400;
    font-style: italic;
    font-size: 0.82rem;
    color: var(--color-ink-faint);
  }
  .board__value {
    font-size: 1.25rem;
    color: var(--color-agate);
    font-weight: 600;
  }
</style>
