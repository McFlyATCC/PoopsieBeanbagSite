---
import Crest from "./Crest.astro";
import { nav, site, withBase } from "../lib/site";
const year = new Date().getFullYear();
---

<footer class="site-foot">
  <div class="band-rule" role="presentation"></div>
  <div class="wrap site-foot__inner">
    <div class="site-foot__brand">
      <Crest size={64} withText={false} />
      <p class="site-foot__memorial">
        In loving memory of<br />
        <strong>{site.honoree}</strong>
      </p>
    </div>

    <nav class="site-foot__nav" aria-label="Footer">
      {nav.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>

    <p class="site-foot__note">
      The Poopsie Beanbag Invitational · {site.tagline}.<br />
      Made with love for the whole family. © {year}
    </p>
  </div>
</footer>

<style>
  .site-foot {
    margin-top: 5rem;
    background: var(--color-lake-deep);
    color: color-mix(in srgb, var(--color-paper) 85%, transparent);
  }
  .site-foot__inner {
    display: grid;
    gap: 2rem;
    padding-block: 3rem;
    grid-template-columns: auto 1fr auto;
    align-items: center;
  }
  .site-foot__brand {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .site-foot__memorial {
    font-family: var(--font-body);
    font-style: italic;
    line-height: 1.4;
    margin: 0;
  }
  .site-foot__memorial strong {
    font-family: var(--font-display);
    font-style: normal;
    color: var(--color-amber);
  }
  .site-foot__nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem 1.25rem;
  }
  .site-foot__nav a {
    font-family: var(--font-accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.78rem;
    color: inherit;
    text-decoration: none;
  }
  .site-foot__nav a:hover {
    color: var(--color-amber);
  }
  .site-foot__note {
    font-family: var(--font-accent);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-align: right;
    line-height: 1.7;
    margin: 0;
    color: color-mix(in srgb, var(--color-paper) 65%, transparent);
  }

  @media (max-width: 820px) {
    .site-foot__inner {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: center;
    }
    .site-foot__note {
      text-align: center;
    }
  }
</style>
